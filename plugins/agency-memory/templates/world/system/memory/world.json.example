  "_comment_memory_guard": "Optional. project_memory_path = where the agent's global auto-memory lives (null = derive from world root, matching Claude Code's ~/.claude/projects/<slug>/memory scheme). guards = file-path patterns -> memory files to surface before a Write/Edit. Empty guards = the PreToolUse hook is a no-op.",
  "memory_guard": {
    "project_memory_path": null,
    "guards": [
      {
        "patterns": ["clients/", "riports/", "audits/"],
        "memories": ["feedback_no_write_without_approval.md"],
        "label": "Client Output"
